<Window x:Class="LANManager.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LAN Manager — Settings" Height="310" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E" Foreground="#F8FAFC">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F8FAFC"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="0,4,0,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#3F3F5F"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#7C3AED"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E2E" Padding="24">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="18" FontWeight="Bold"
                       Foreground="#A78BFA" Margin="0,0,0,20"/>

            <!-- Poll interval -->
            <Label Content="Poll Interval"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="PollSlider" Grid.Column="0" Minimum="1" Maximum="10"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="PollSlider_ValueChanged" VerticalAlignment="Center"/>
                <TextBlock x:Name="PollLabel" Grid.Column="1" VerticalAlignment="Center"
                           Margin="8,0,0,0" Foreground="#94A3B8"/>
            </Grid>

            <!-- Smoothing window -->
            <Label Content="Smoothing Window (1 = raw, 2–10 = average over N samples)"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SmoothSlider" Grid.Column="0" Minimum="1" Maximum="10"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="SmoothSlider_ValueChanged" VerticalAlignment="Center"/>
                <TextBlock x:Name="SmoothLabel" Grid.Column="1" VerticalAlignment="Center"
                           Margin="8,0,0,0" Foreground="#94A3B8"/>
            </Grid>

            <!-- Smoothing explanation -->
            <Border Background="#252535" CornerRadius="6" Padding="10,8" Margin="0,0,0,20">
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#64748B"
                    Text="1 = raw mode, no smoothing (default). 2–10 = rolling average over N samples — higher values are smoother but slower to react to sudden bursts. Poll interval is a lightweight kernel counter read, not packet capture — 1s adds essentially zero CPU or network load."/>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Background="#334155" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="Save" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
