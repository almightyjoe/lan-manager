<Window x:Class="LANManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="LAN Manager" Height="600" Width="900"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark">#1E1E2E</SolidColorBrush>
        <SolidColorBrush x:Key="BgPanel">#252535</SolidColorBrush>
        <SolidColorBrush x:Key="Accent">#7C3AED</SolidColorBrush>
        <SolidColorBrush x:Key="AccentLight">#A78BFA</SolidColorBrush>
        <SolidColorBrush x:Key="TextPrimary">#F8FAFC</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondary">#94A3B8</SolidColorBrush>
        <SolidColorBrush x:Key="Green">#22C55E</SolidColorBrush>
        <SolidColorBrush x:Key="Red">#EF4444</SolidColorBrush>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1A2A"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1A1A2A"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="{StaticResource BgDark}"
            BorderBrush="#3F3F5F" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="Transparent" MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="◈" Foreground="{StaticResource AccentLight}" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="LAN Manager" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Button Content="─" Foreground="{StaticResource TextSecondary}" Background="Transparent"
                            BorderThickness="0" Width="32" Click="Minimize_Click" Cursor="Hand"/>
                    <Button Content="✕" Foreground="{StaticResource TextSecondary}" Background="Transparent"
                            BorderThickness="0" Width="32" Click="Close_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="8,0,8,8">
                <TabItem Header="📊 Speed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Live stats row -->
                        <Grid Grid.Row="0" Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                                    CornerRadius="8" Margin="0,0,4,0" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="↑ UPLOAD" Foreground="{StaticResource TextSecondary}"
                                               FontSize="10" FontWeight="Bold"/>
                                    <TextBlock x:Name="UploadLabel" Text="0 KB/s"
                                               Foreground="{StaticResource AccentLight}"
                                               FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{StaticResource BgPanel}"
                                    CornerRadius="8" Margin="4,0,0,0" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="↓ DOWNLOAD" Foreground="{StaticResource TextSecondary}"
                                               FontSize="10" FontWeight="Bold"/>
                                    <TextBlock x:Name="DownloadLabel" Text="0 KB/s"
                                               Foreground="{StaticResource Green}"
                                               FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Chart -->
                        <Border Grid.Row="1" Background="{StaticResource BgPanel}" CornerRadius="8" Padding="8">
                            <lvc:CartesianChart x:Name="SpeedChart" Series="{Binding SpeedSeries}"
                                                XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"/>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="⚙ Processes">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Margin="0,8,0,8"
                                   Text="Active network processes — sorted by total bandwidth"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <DataGrid Grid.Row="1" x:Name="ProcessGrid" AutoGenerateColumns="False"
                                  IsReadOnly="True" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="70"/>
                                <DataGridTextColumn Header="Upload" Binding="{Binding UploadFormatted}" Width="100"/>
                                <DataGridTextColumn Header="Download" Binding="{Binding DownloadFormatted}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="🔍 LAN Scan">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8,0,8">
                            <Button x:Name="ScanBtn" Content="Scan Network" Style="{StaticResource PrimaryBtn}"
                                    Click="ScanBtn_Click"/>
                            <TextBlock x:Name="ScanStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        </StackPanel>

                        <ProgressBar Grid.Row="1" x:Name="ScanProgress" Height="4" Margin="0,0,0,8"
                                     Minimum="0" Maximum="254" Value="0"
                                     Foreground="{StaticResource Accent}" Background="#2A2A3A"
                                     BorderThickness="0"/>

                        <DataGrid Grid.Row="2" x:Name="DeviceGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="130"/>
                                <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="*"/>
                                <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}" Width="160"/>
                                <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen, StringFormat=\{0:HH:mm:ss\}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="🔔 Alerts">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="0,8,0,8"
                                   Text="Get notified when a process exceeds a bandwidth threshold."
                                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>

                        <!-- Add alert form -->
                        <Border Grid.Row="1" Background="{StaticResource BgPanel}"
                                CornerRadius="8" Padding="12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Process:" Foreground="{StaticResource TextSecondary}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="AlertProcessBox" Width="150" Background="#1A1A2A"
                                         Foreground="{StaticResource TextPrimary}" BorderBrush="#3F3F5F"
                                         Padding="6,4" VerticalAlignment="Center"/>
                                <TextBlock Text="Threshold (MB/s):" Foreground="{StaticResource TextSecondary}"
                                           VerticalAlignment="Center" Margin="12,0,8,0"/>
                                <TextBox x:Name="AlertThresholdBox" Width="70" Background="#1A1A2A"
                                         Foreground="{StaticResource TextPrimary}" BorderBrush="#3F3F5F"
                                         Padding="6,4" Text="1.0" VerticalAlignment="Center"/>
                                <Button Content="Add Alert" Style="{StaticResource PrimaryBtn}"
                                        Margin="12,0,0,0" Click="AddAlert_Click"/>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="2" x:Name="AlertGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="*"/>
                                <DataGridTextColumn Header="Threshold (MB/s)" Binding="{Binding ThresholdMbps, StringFormat=F1}" Width="130"/>
                                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Alert log -->
                        <Border Grid.Row="3" Background="{StaticResource BgPanel}"
                                CornerRadius="8" Padding="12" Margin="0,8,0,0" MaxHeight="120">
                            <ScrollViewer x:Name="AlertScroll" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="AlertLog" Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
